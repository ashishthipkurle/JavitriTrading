# Database (PostgreSQL)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/tradepro?schema=public"

# NextAuth Secrets
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"

# Razorpay Keys
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Cloudinary (Storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Resend (Email)
RESEND_API_KEY="re_123456789"

# Admin 2FA (otplib)
ADMIN_2FA_SECRET="your_totp_secret_key"

# Nodemailer Custom SMTP Configuration
# Replace these with your actual business email / SMTP provider details
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM='"Trader FD" <noreply@traderfd.com>'
